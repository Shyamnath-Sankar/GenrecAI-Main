{
    "rewrites": [
        {
            "source": "/images/:path*",
            "destination": "https://eagediffandfnavqcxnw.supabase.co/storage/v1/object/public/blog-images/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/images/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}